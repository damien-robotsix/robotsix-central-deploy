{
  "host": "0.0.0.0",
  "port": 8100,
  "api_key": "",
  "auth_username": "",
  "auth_password": "",
  "store_backend": "memory",
  "store_path": "lifecycle_state.yaml",
  "execution_backend": "docker_sdk",
  "component_config_store_path": "data/component_configs.json",
  "docker_socket_url": "unix:///var/run/docker.sock",
  "docker_sdk_timeout": 120,
  "disk_path": "/",
  "disk_warn_pct": 10.0,
  "env_store_path": "component_env.json",
  "secret_key_path": "secrets.key",
  "config_yaml_store_path": "data/component_config_yaml.json",
  "deploy_history_store_path": "data/deploy_history.json",
  "self_update_watchtower_image": "containrrr/watchtower:1.7.1",
  "self_update_docker_api_version": "1.44",
  "registry_check_ttl": 300,
  "registry_check_interval": 300,
  "system_settings_path": "data/system_settings.json",
  "log_level": "INFO",
  "gateway_base_domain": "",
  "volume_audit_enabled": false,
  "volume_audit_interval_seconds": 3600,
  "volume_audit_snapshot_path": "data/volume_audit_snapshots.json",
  "volume_audit_findings_path": "data/volume_audit_findings.json",
  "volume_audit_growth_threshold_pct": 10.0,
  "volume_audit_min_delta_bytes": 10485760,
  "board_api_url": "",
  "board_api_token": "",
  "board_repo_id": "",
  "caretaker_enabled": false,
  "caretaker_interval_hours": 24,
  "mill_component_id": "",
  "image_auto_prune": false,
  "virtual_components": [
    {
      "id": "langfuse",
      "chat_base_url": "http://central-deploy:8100",
      "chat_skill_endpoint": "/chat-skill",
      "chat_skill": "# Langfuse\n\nLLM observability and tracing platform.\n\n## Endpoints\n- `GET /chat/langfuse/projects` — list configured project aliases\n- `GET /chat/langfuse/{project}/traces` — list traces (supports `?limit=`, `?page=`, `?tags=`, `?name=`, `?sessionId=`, `?fromTimestamp=`)\n- `GET /chat/langfuse/{project}/traces/{traceId}` — single trace detail\n- `GET /chat/langfuse/{project}/observations` — list observations\n- `GET /chat/langfuse/{project}/observations/{observationId}` — single observation detail\n\n## Authentication\n\nNone required.  The deploy server injects HTTP Basic Auth server-side —\nthe chat container never sees the credentials.\n\n## Projects\n\nUse the `{project}` path parameter to select which Langfuse project's traces to query.  Configured project aliases are listed at `GET /chat/langfuse/projects`.  New project aliases can be added via the `langfuse_projects` config field (dict of alias → {public_key, secret_key}).",
      "auth_type": "",
      "auth_username_env": "",
      "auth_password_env": ""
    },
    {
      "id": "deploy",
      "chat_base_url": "http://central-deploy:8100",
      "chat_skill_endpoint": "/chat-skill",
      "chat_skill": "",
      "auth_type": "header",
      "auth_header_name": "X-API-Key",
      "auth_token_env": "DEPLOY_API_KEY"
    }
  ],
  "llmio_tier_config": {
    "level1": {
      "provider": "openai",
      "model": "gpt-4o-mini"
    },
    "level2": {
      "provider": "openai",
      "model": "gpt-4o"
    },
    "level3": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-20250514"
    },
    "level4": {
      "provider": "anthropic",
      "model": "claude-opus-4-20250514"
    }
  }
}
