{
  "openapi": "3.1.0",
  "info": {
    "title": "robotsix-central-deploy Lifecycle API",
    "description": "Start, stop, restart, and inspect suite services.",
    "version": "0.1.0"
  },
  "paths": {
    "/services": {
      "get": {
        "summary": "List managed services",
        "operationId": "list_services_services_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceListResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden \u2014 invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorDetail"
                }
              }
            }
          }
        }
      }
    },
    "/services/{name}": {
      "get": {
        "summary": "Get service status",
        "operationId": "get_service_status_services__name__get",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Name"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceStatus"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden \u2014 invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorDetail"
                }
              }
            }
          },
          "404": {
            "description": "Service not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorDetail"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/services/{name}/start": {
      "post": {
        "summary": "Start a service (idempotent)",
        "operationId": "start_service_services__name__start_post",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Name"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ActionResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden \u2014 invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorDetail"
                }
              }
            }
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorDetail"
                }
              }
            },
            "description": "Not Found"
          },
          "409": {
            "description": "Already in requested state",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorDetail"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/services/{name}/stop": {
      "post": {
        "summary": "Stop a service (idempotent)",
        "operationId": "stop_service_services__name__stop_post",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Name"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ActionResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden \u2014 invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorDetail"
                }
              }
            }
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorDetail"
                }
              }
            },
            "description": "Not Found"
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorDetail"
                }
              }
            },
            "description": "Conflict"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/services/{name}/restart": {
      "post": {
        "summary": "Restart a service (idempotent)",
        "operationId": "restart_service_services__name__restart_post",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Name"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ActionResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden \u2014 invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorDetail"
                }
              }
            }
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorDetail"
                }
              }
            },
            "description": "Not Found"
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorDetail"
                }
              }
            },
            "description": "Conflict"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ActionResponse": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "action": {
            "type": "string",
            "title": "Action"
          },
          "previous_state": {
            "$ref": "#/components/schemas/ServiceState"
          },
          "current_state": {
            "$ref": "#/components/schemas/ServiceState"
          },
          "detail": {
            "type": "string",
            "title": "Detail",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "name",
          "action",
          "previous_state",
          "current_state"
        ],
        "title": "ActionResponse",
        "description": "Generic response for start / stop / restart requests."
      },
      "ErrorDetail": {
        "properties": {
          "error": {
            "type": "string",
            "title": "Error"
          },
          "detail": {
            "type": "string",
            "title": "Detail",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "error"
        ],
        "title": "ErrorDetail",
        "description": "Structured error response body."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ServiceListItem": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "state": {
            "$ref": "#/components/schemas/ServiceState"
          }
        },
        "type": "object",
        "required": [
          "name",
          "state"
        ],
        "title": "ServiceListItem",
        "description": "Summary entry returned by ``GET /services``."
      },
      "ServiceListResponse": {
        "properties": {
          "services": {
            "items": {
              "$ref": "#/components/schemas/ServiceListItem"
            },
            "type": "array",
            "title": "Services"
          }
        },
        "type": "object",
        "required": [
          "services"
        ],
        "title": "ServiceListResponse",
        "description": "Wrapper for the service list endpoint."
      },
      "ServiceState": {
        "type": "string",
        "enum": [
          "stopped",
          "starting",
          "running",
          "stopping",
          "restarting",
          "failed",
          "unknown"
        ],
        "title": "ServiceState",
        "description": "The seven lifecycle states a managed service can be in."
      },
      "ServiceStatus": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "state": {
            "$ref": "#/components/schemas/ServiceState"
          },
          "image": {
            "type": "string",
            "title": "Image",
            "default": ""
          },
          "last_error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last Error"
          },
          "updated_at": {
            "type": "number",
            "title": "Updated At"
          }
        },
        "type": "object",
        "required": [
          "name",
          "state"
        ],
        "title": "ServiceStatus",
        "description": "Full status returned by ``GET /services/{name}``."
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}
